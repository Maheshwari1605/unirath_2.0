# ---- Contact form ----

# Option 1: Google Apps Script (frontend posts directly to your script)
# Get URL: Google Sheet → Extensions → Apps Script → Deploy → Web app → Copy exec URL
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Option 2: Backend (Sheet API + SMTP) – only if you run a server that uses these
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=Inquiries
NOTIFICATION_EMAIL=your-notification@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp@gmail.com
SMTP_PASS=your-app-password
